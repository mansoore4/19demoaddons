<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action for Allowance Types -->
    <record id="action_hr_allowance_type" model="ir.actions.act_window">
        <field name="name">Allowance Types</field>
        <field name="res_model">hr.allowance.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Submenu: Allowance Types (attaches to the existing root menu) -->
    <menuitem id="menu_hr_allowance_type"
              name="Allowance Types"
              parent="menu_hr_allowance_root"
              action="action_hr_allowance_type"
              sequence="20"
              groups="hr.group_hr_manager"/>

    <!-- List View -->
    <record id="view_hr_allowance_type_list" model="ir.ui.view">
        <field name="name">hr.allowance.type.list</field>
        <field name="model">hr.allowance.type</field>
        <field name="arch" type="xml">
            <list string="Allowance Types">
                <field name="name"/>
                <field name="description"/> <!-- 🟢 Added field -->
                <field name="type_code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hr_allowance_type_form" model="ir.ui.view">
        <field name="name">hr.allowance.type.form</field>
        <field name="model">hr.allowance.type</field>
        <field name="arch" type="xml">
            <form string="Allowance Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/> <!-- 🟢 Added field -->
                        <field name="type_code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>